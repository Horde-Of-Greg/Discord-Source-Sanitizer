{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",

        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,

        "declaration": false,
        "sourceMap": true,

        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,

        "strictPropertyInitialization": false,
        "noImplicitReturns": true,

        "types": ["node"]
    },
    "include": ["src/**/*.ts", "./*.ts"]
}
