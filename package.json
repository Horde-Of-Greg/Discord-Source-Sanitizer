{
    "name": "ts-node-template-d-alessian",
    "version": "0.0.1",
    "description": "A template for my personal node typescript projects.",
    "license": "MIT",
    "author": "Alessian Dormal",
    "type": "module",
    "main": "dist/main.js",
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "start": "node dist/main.js",
        "dev": "tsx watch src/index.ts",
        "tscheck": "tsc --noEmit",
        "lint": "eslint . --fix",
        "lint:check": "eslint ."
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.9.1",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-n": "^18.0.1",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-sonarjs": "^4.0.3",
        "eslint-plugin-unused-imports": "^4.3.0",
        "globals": "^17.6.0",
        "jiti": "^2.7.0",
        "prettier": "^3.8.3",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0"
    }
}
