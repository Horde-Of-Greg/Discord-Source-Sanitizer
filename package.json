    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/linkify-it": "5.0.0",
        "@types/node": "^25.9.2",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-n": "^18.0.1",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-sonarjs": "^4.0.3",
        "eslint-plugin-unused-imports": "^4.3.0",
        "globals": "^17.6.0",
        "jiti": "^2.7.0",
        "prettier": "^3.8.3",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1"
    },
    "dependencies": {
        "csv-parse": "^6.2.1",
        "discord.js": "^14.26.4",
        "dotenv": "^17.4.2",
        "linkify-it": "5.0.1",
        "zod": "^4.4.3"
