{
    "name": "ts-node-template-d-alessian",
    "version": "1.0.0",
    "description": "A template for my personal node typescript projects.",
    "license": "MIT",
    "author": "Alessian Dormal",
    "type": "module",
    "main": "dist/main.js",
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "start": "node dist/main.js",
        "dev": "NODE_ENV=development tsx watch src/main.ts",
        "tscheck": "tsc --noEmit",
        "lint": "eslint . --fix",
        "lint:check": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "bump:major": "npm version major --force && git push origin main --tags",
        "bump:minor": "npm version minor --force && git push origin main --tags",
        "bump:patch": "npm version patch --force && git push origin main --tags"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/linkify-it": "5.0.0",
        "@types/node": "^25.9.1",
        "@vitest/coverage-v8": "^4.1.9",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-n": "^18.1.0",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-sonarjs": "^4.1.0",
        "eslint-plugin-unused-imports": "^4.3.0",
        "globals": "^17.6.0",
        "jiti": "^2.7.0",
        "prettier": "^3.8.4",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.1",
        "vitest": "^4.1.9"
    },
    "dependencies": {
        "csv-parse": "^6.2.1",
        "discord.js": "^14.26.4",
        "dotenv": "^17.4.2",
        "linkify-it": "5.0.1",
        "zod": "^4.4.3"
    }
}
